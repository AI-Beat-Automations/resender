{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "globalEnv": [
    "APP_URL",
    "AUTH_SECRET",
    "API_KEY_PEPPER",
    "DATABASE_URL",
    "TOKEN_ENCRYPTION_KEY",
    "META_APP_SECRET",
    "META_VERIFY_TOKEN",
    "NODE_ENV",
    "NEXT_PUBLIC_META_APP_ID",
    "NEXT_PUBLIC_META_CONFIG_ID"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "format": {
      "dependsOn": ["^format"]
    },
    "test": {
      "dependsOn": ["^test"],
      "cache": false,
      "persistent": true
    },
    "test:run": {
      "dependsOn": ["^test:run"]
    },
    "typecheck": {
      "dependsOn": ["^typecheck"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
